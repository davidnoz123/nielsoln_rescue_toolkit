{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hardware_profile.schema.json",
  "title": "m04 hardware_profile",
  "description": "Hardware inventory written by m04_hardware_profile. Log glob: logs/hardware_profile_*.json",
  "type": "object",
  "required": ["timestamp", "system", "form_factor", "boot_mode", "bios", "cpu", "ram", "storage", "gpu", "network"],
  "additionalProperties": true,
  "properties": {
    "timestamp": { "type": "string", "description": "ISO 8601 UTC" },
    "system": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "manufacturer":    { "type": "string" },
        "product_name":    { "type": "string" },
        "product_version": { "type": "string" },
        "serial_number":   { "type": "string" },
        "chassis_type":    { "type": "string" }
      }
    },
    "form_factor": { "type": "string", "enum": ["laptop", "desktop", "unknown"] },
    "boot_mode":   { "type": "string", "examples": ["UEFI", "BIOS/Legacy"] },
    "bios": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "vendor":  { "type": "string" },
        "version": { "type": "string" },
        "date":    { "type": "string" }
      }
    },
    "cpu": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model":          { "type": "string" },
        "architecture":   { "type": "string" },
        "physical_cores": { "type": "integer" },
        "logical_cores":  { "type": "integer" },
        "sockets":        { "type": "integer" }
      }
    },
    "ram": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "total_mib":       { "type": "integer" },
        "total_gib":       { "type": "number" },
        "type":            { "type": "string" },
        "speed":           { "type": "string" },
        "slots_populated": {},
        "slots_total":     {}
      }
    },
    "storage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "device":       { "type": "string" },
          "model":        { "type": "string" },
          "type":         { "type": "string", "examples": ["HDD", "SSD", "NVMe SSD", "eMMC/SD", "unknown"] },
          "size_gib":     { "type": "number" },
          "smart_health": { "type": "string", "examples": ["PASSED", "FAILED", "unknown"] }
        }
      }
    },
    "gpu":     { "type": "array", "items": { "type": "string" } },
    "network": { "type": "array", "items": { "type": "string" } }
  }
}
