{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "clamav_scan.schema.json",
  "title": "ClamAV Scan Assessment",
  "description": "Output of m18_clamav_scan.py — comprehensive ClamAV evidence-based antivirus assessment",
  "type": "object",
  "additionalProperties": true,
  "required": ["generated", "target", "scan_status"],
  "properties": {
    "generated": {
      "type": "string",
      "description": "ISO-8601 timestamp of when this report was generated"
    },
    "target": {
      "type": "string",
      "description": "Path to the mounted offline Windows installation"
    },
    "profile": {
      "type": "string",
      "enum": ["quick", "thorough"],
      "description": "ClamAV scan profile used"
    },
    "scan_status": {
      "type": "string",
      "enum": ["clean", "infected", "partial", "error", "no_clamav", "analyze_only", "unknown"]
    },
    "infected_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path":  { "type": "string" },
          "virus": { "type": "string" }
        }
      }
    },
    "definitions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Metadata for each ClamAV database (main, daily, bytecode)",
      "properties": {
        "main":     { "$ref": "#/definitions/db_meta" },
        "daily":    { "$ref": "#/definitions/db_meta" },
        "bytecode": { "$ref": "#/definitions/db_meta" }
      }
    },
    "scan_scope": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "paths_scanned":             { "type": "array", "items": { "type": "string" } },
        "paths_skipped":             { "type": "array", "items": { "type": "string" } },
        "directories_scanned":       { "type": ["integer", "null"] },
        "files_scanned":             { "type": ["integer", "null"] },
        "total_bytes_scanned":       { "type": ["integer", "null"] },
        "recursion_enabled":         { "type": "boolean" },
        "archives_scanned":          { "type": "boolean" },
        "max_file_size":             { "type": ["string", "null"] },
        "max_scan_size":             { "type": ["string", "null"] },
        "include_system_directories":{ "type": "boolean" },
        "estimate_note":             { "type": "string" }
      }
    },
    "scan_execution": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "scan_start_time":             { "type": "string" },
        "scan_end_time":               { "type": "string" },
        "duration_seconds":            { "type": ["number", "null"] },
        "infected_count":              { "type": "integer" },
        "errors_encountered":          { "type": "integer" },
        "files_skipped_due_to_errors": { "type": "integer" },
        "permission_denied_paths":     { "type": "array", "items": { "type": "string" } },
        "oom_killed":                  { "type": "boolean" },
        "analyze_only":                { "type": "boolean" },
        "scan_status":                 { "type": "string" }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "system32_scanned":          { "type": "boolean" },
        "syswow64_scanned":          { "type": "boolean" },
        "windows_temp_scanned":      { "type": "boolean" },
        "users_scanned":             { "type": "boolean" },
        "appdata_scanned":           { "type": "boolean" },
        "program_files_scanned":     { "type": "boolean" },
        "program_files_x86_scanned": { "type": "boolean" },
        "programdata_scanned":       { "type": "boolean" },
        "dirs_not_scanned":          { "type": "array", "items": { "type": "string" } },
        "overall_estimate":          {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        }
      }
    },
    "scan_gaps": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "skipped_files_count":  { "type": "integer" },
        "skipped_paths":        { "type": "array", "items": { "type": "string" } },
        "size_limited_files":   { "type": "array", "items": { "type": "string" } },
        "error_paths":          { "type": "array", "items": { "type": "string" } },
        "permission_denied":    { "type": "array", "items": { "type": "string" } },
        "dirs_not_scanned":     { "type": "array", "items": { "type": "string" } },
        "archives_skipped":     { "type": "string" },
        "archives_skipped_flag":{ "type": "boolean" },
        "max_file_size":        { "type": ["string", "null"] },
        "max_scan_size":        { "type": ["string", "null"] }
      }
    },
    "file_type_limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "heuristic_limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cross_module_correlation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "persistence_log":          { "type": ["string", "null"] },
        "persistence_suspicious":   { "type": "integer" },
        "service_analysis_log":     { "type": ["string", "null"] },
        "service_suspicious":       { "type": "integer" },
        "device_manager_log":       { "type": ["string", "null"] },
        "device_problem_count":     { "type": "integer" },
        "system_integrity_log":     { "type": ["string", "null"] },
        "system_integrity_verdict": { "type": ["string", "null"] },
        "cross_module_flags":       { "type": "array", "items": { "type": "string" } },
        "unexplained_signals":      { "type": "array", "items": { "type": "string" } }
      }
    },
    "scan_confidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "score":     { "type": "integer" },
        "max_score": { "type": "integer" },
        "reasons":   { "type": "array", "items": { "type": "string" } }
      }
    },
    "miss_analysis": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "coverage_gaps":           { "type": "array", "items": { "type": "string" } },
        "file_type_limitations":   { "type": "array", "items": { "type": "string" } },
        "heuristic_limitations":   { "type": "array", "items": { "type": "string" } },
        "cross_module_flags":      { "type": "array", "items": { "type": "string" } },
        "unexplained_signals":     { "type": "array", "items": { "type": "string" } },
        "confidence_adjustment":   {
          "type": "string",
          "enum": ["lowered", "unchanged"]
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "db_meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "file":        { "type": ["string", "null"] },
        "version":     { "type": ["string", "null"] },
        "build_time":  { "type": ["string", "null"] },
        "sig_count":   { "type": ["integer", "null"] },
        "age_days":    { "type": ["integer", "null"] },
        "parse_error": { "type": ["string", "null"] }
      }
    }
  }
}
