{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "device_manager.schema.json",
  "title": "DEVICE_MANAGER_FULL_STATUS",
  "description": "Device Manager full-status inventory from offline registry written by m27_device_manager. Log glob: logs/device_manager_*.json",
  "type": "object",
  "required": ["target", "timestamp", "total", "flagged_count", "devices"],
  "additionalProperties": true,
  "properties": {
    "report_type": {
      "type": "string",
      "enum": ["DEVICE_MANAGER_FULL_STATUS"],
      "description": "Report type discriminator. Present in v2+ logs."
    },
    "target":        { "type": "string" },
    "timestamp":     { "type": "string" },
    "total":         { "type": "integer" },
    "flagged_count": { "type": "integer" },
    "missing_drivers": {
      "type": ["integer", "null"],
      "description": "Count of devices with no driver installed (problem code 28 = CM_PROB_FAILED_INSTALL or no driver key)"
    },
    "disabled_devices": {
      "type": ["integer", "null"],
      "description": "Count of devices explicitly disabled (problem code 22 = CM_PROB_DISABLED)"
    },
    "problem_code_devices": {
      "type": ["integer", "null"],
      "description": "Count of devices with any non-zero CM_PROB_* problem code"
    },
    "missing_driver_files": {
      "type": ["integer", "null"],
      "description": "Count of devices whose driver binary files are absent from the filesystem"
    },
    "old_drivers": {
      "type": ["integer", "null"],
      "description": "Count of drivers with a driver_date older than a configurable threshold (default: 5 years)"
    },
    "unsigned_drivers": {
      "type": ["integer", "null"],
      "description": "Count of driver files where signed=false"
    },
    "devices_by_class": {
      "type": ["object", "null"],
      "additionalProperties": { "type": "integer" },
      "description": "Map of device class name → count (e.g. {\"Net\": 3, \"USB\": 12, \"DiskDrive\": 2})"
    },
    "driver_events": {
      "type": "array",
      "description": "Driver/device events correlated from System.evtx (Event IDs 7000–7045, 219, 411 etc.)",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "event_id":    { "type": "integer" },
          "time":        { "type": "string" },
          "provider":    { "type": "string" },
          "device_id":   { "type": ["string", "null"], "description": "Correlated device instance ID if matched" },
          "description": { "type": "string" },
          "data":        { "type": "object", "additionalProperties": true }
        }
      }
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "bus":             { "type": "string" },
          "device_id":       { "type": "string" },
          "instance":        { "type": "string" },
          "description":     { "type": "string" },
          "class":           { "type": "string" },
          "class_guid":      { "type": "string" },
          "manufacturer":    { "type": "string" },
          "hardware_ids":    { "type": "array", "items": { "type": "string" } },
          "compatible_ids":  { "type": "array", "items": { "type": "string" }, "description": "CompatibleIDs from Enum\\<bus>\\<device> registry key" },
          "driver_version":  { "type": "string" },
          "driver_provider": { "type": "string" },
          "driver_date":     { "type": "string" },
          "driver_key":      { "type": ["string", "null"], "description": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\<driverKey> reference" },
          "inf_name":        { "type": ["string", "null"], "description": "INF filename used to install the device (from InfName value)" },
          "service_binding": {
            "type": ["object", "null"],
            "additionalProperties": true,
            "description": "Service registry entry correlated from driver_key",
            "properties": {
              "service_name":  { "type": "string" },
              "image_path":    { "type": ["string", "null"] },
              "start_type":    { "type": ["integer", "null"] },
              "start_type_str":{ "type": ["string", "null"] },
              "object_name":   { "type": ["string", "null"] },
              "error_control": { "type": ["integer", "null"] }
            }
          },
          "upper_filters":   { "type": "array", "items": { "type": "string" }, "description": "UpperFilters driver stack entries" },
          "lower_filters":   { "type": "array", "items": { "type": "string" }, "description": "LowerFilters driver stack entries" },
          "config_flags":    {},
          "config_flags_decoded": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Human-readable decode of ConfigFlags bitmask (e.g. CONFIGFLAG_REMOVED, CONFIGFLAG_FAILEDINSTALL)"
          },
          "problem_code":    {},
          "problem_code_decoded": {
            "type": ["string", "null"],
            "description": "Human-readable decode of CM_PROB_* error code (e.g. CM_PROB_FAILED_START, CM_PROB_DISABLED)"
          },
          "problem_desc":    { "type": ["string", "null"] },
          "present":         { "type": ["boolean", "null"], "description": "True if device is currently present (SPDRP_PHYSICAL_DEVICE_OBJECT_NAME or DeviceDesc present)" },
          "disabled":        { "type": ["boolean", "null"], "description": "True if device is explicitly disabled (problem_code 22 = CM_PROB_DISABLED)" },
          "driver_files": {
            "type": "array",
            "description": "Driver binary files associated with this device (from service ImagePath + INF CopyFiles)",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "path":          { "type": "string" },
                "exists":        { "type": ["boolean", "null"] },
                "size_bytes":    { "type": ["integer", "null"] },
                "sha256":        { "type": ["string", "null"] },
                "version":       { "type": ["string", "null"] },
                "publisher":     { "type": ["string", "null"] },
                "signed":        { "type": ["boolean", "null"] }
              }
            }
          },
          "file_evidence": {
            "type": "array",
            "description": "Integrity/anomaly evidence from cross-referencing driver files with system_integrity findings",
            "items": { "type": "string" }
          },
          "evtx_events": {
            "type": "array",
            "description": "System.evtx events correlated to this specific device instance",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "event_id":    { "type": "integer" },
                "time":        { "type": "string" },
                "description": { "type": "string" }
              }
            }
          },
          "flagged":         { "type": "boolean" }
        }
      }
    }
  }
}
