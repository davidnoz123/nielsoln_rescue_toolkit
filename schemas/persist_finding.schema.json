{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "persist_finding.schema.json",
  "title": "m01 persist_finding (JSONL line)",
  "description": "Each line in a m01_persistence_scan JSONL log file. Log glob: logs/persist_*.jsonl",
  "type": "object",
  "required": ["type", "source", "command"],
  "additionalProperties": true,
  "properties": {
    "type": {
      "type": "string",
      "enum": ["startup", "task", "service", "registry", "info", "error"],
      "description": "Finding category"
    },
    "source":    { "type": "string", "description": "Registry key, file path, or task scheduler path" },
    "command":   { "type": "string" },
    "user":      { "type": ["string", "null"] },
    "score":     { "type": "integer", "minimum": 0, "maximum": 100 },
    "risk":      { "type": "string", "enum": ["low", "medium", "high"] },
    "reasons":   { "type": "array", "items": { "type": "string" } }
  }
}
