{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event_archive_chunk.schema.json",
  "title": "m25 event_archive JSONL chunk lines",
  "description": "Each line in a m25 event archive chunk file (logs/event_archive_chunks/*.jsonl). Two line types: chunk_header and event.",
  "oneOf": [
    {
      "title": "chunk_header",
      "type": "object",
      "required": ["type", "channel", "machine_id", "run_time"],
      "additionalProperties": true,
      "properties": {
        "type":       { "type": "string", "const": "chunk_header" },
        "channel":    { "type": "string" },
        "machine_id": { "type": "string" },
        "run_time":   { "type": "string" }
      }
    },
    {
      "title": "event",
      "type": "object",
      "required": ["type", "record_id", "timestamp", "event_id", "provider", "computer", "data"],
      "additionalProperties": true,
      "properties": {
        "type":        { "type": "string", "const": "event" },
        "record_id":   { "type": "integer" },
        "timestamp":   { "type": "string" },
        "event_id":    { "type": "integer" },
        "provider":    { "type": "string" },
        "computer":    { "type": "string" },
        "data":        { "type": "object", "additionalProperties": true },
        "raw_xml":     { "type": "string" },
        "raw_sha256":  { "type": "string" }
      }
    }
  ]
}
