{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "system_summary.schema.json",
  "title": "m17 system_summary",
  "description": "Cross-module summary written by m17_system_summary. Log glob: logs/system_summary_*.json",
  "type": "object",
  "required": ["generated", "target", "sections"],
  "additionalProperties": true,
  "properties": {
    "generated": { "type": "string" },
    "target":    { "type": "string" },
    "sections": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hardware": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":      { "type": "string" },
                "machine":  { "type": "string" },
                "cpu":      { "type": "string" },
                "ram_gb":   {},
                "disks":    { "type": "array", "items": { "type": "string" } },
                "bios_date":{ "type": "string" }
              }
            }
          ]
        },
        "disk": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log": { "type": "string" },
                "drives": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "model":   { "type": "string" },
                      "verdict": { "type": "string" },
                      "flags":   { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            }
          ]
        },
        "thermal": {
          "description": "Legacy/passive thermal summary (v1). Only idle temperatures from WMI/ACPI sensor readback — no active stress test. Superseded by thermal_analysis (v2) when m09_thermal_health runs a response test.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":         { "type": "string" },
                "verdict":     { "type": "string" },
                "warnings":    { "type": "array", "items": { "type": "string" } },
                "hottest_c":   { "type": ["number", "null"] },
                "confidence":  { "type": ["string", "null"], "enum": ["high", "medium", "low", "none", null], "description": "Low — passive sensor only, no load test" },
                "limitations": { "type": "array", "items": { "type": "string" }, "description": "e.g. ['passive_sensors_only', 'no_load_test']" }
              }
            }
          ]
        },
        "clamav": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":               { "type": "string" },
                "verdict":           { "type": "string" },
                "infected":          { "type": "integer" },
                "scanned":           { "type": ["integer", "null"] },
                "confidence":        { "type": ["string", "null"] },
                "coverage_estimate": { "type": ["string", "null"] },
                "definitions_age":   { "type": ["integer", "null"] },
                "recommendations":   { "type": "array", "items": { "type": "string" } }
              }
            }
          ]
        },
        "logon": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":            { "type": "string" },
                "verdict":        { "type": "string" },
                "failed_logons":  { "type": "integer" },
                "lockouts":       { "type": "integer" },
                "pw_changes":     { "type": "integer" },
                "explicit_creds": { "type": "integer" }
              }
            }
          ]
        },
        "persistence": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":        { "type": "string" },
                "total":      { "type": "integer" },
                "suspicious": { "type": "integer" }
              }
            }
          ]
        },
        "services": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":         { "type": "string" },
                "verdict":     { "type": "string" },
                "total":       {},
                "suspicious":  { "type": "integer" },
                "deleted":     { "type": "integer" },
                "third_party": { "type": "integer" },
                "auto_start":  { "type": "integer" }
              }
            }
          ]
        },
        "software": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":   { "type": "string" },
                "total": { "type": "integer" },
                "flags": { "type": "object", "additionalProperties": { "type": "integer" } }
              }
            }
          ]
        },
        "upgrade": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":            { "type": "string" },
                "recommendation": { "type": "string" },
                "count":          { "type": "integer" }
              }
            }
          ]
        },
        "system_integrity": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":                    { "type": "string" },
                "verdict":                { "type": "string" },
                "confidence":             { "type": "string" },
                "scan_status":            { "type": "string" },
                "files_checked":          { "type": "integer" },
                "anomalous_files":        { "type": "integer" },
                "missing_files":          { "type": "integer" },
                "windows_version_hint":   { "type": ["string", "null"] }
              }
            }
          ]
        },
        "execution_surface": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":              { "type": "string" },
                "services_analysed":{ "type": "integer" },
                "critical_count":   { "type": "integer" },
                "high_count":       { "type": "integer" },
                "risk_distribution":{ "type": "object", "additionalProperties": { "type": "integer" } }
              }
            }
          ]
        },
        "clamav_confidence": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "description": "Enhanced ClamAV confidence and miss-analysis summary",
              "properties": {
                "log":             { "type": "string" },
                "scan_status":     { "type": "string" },
                "infected_count":  { "type": "integer" },
                "confidence_level":{ "type": "string" },
                "confidence_score":{ "type": "integer" },
                "coverage_estimate":{ "type": "string" },
                "miss_analysis_flags":{ "type": "array", "items": { "type": "string" } },
                "unexplained_signals":{ "type": "array", "items": { "type": "string" } }
              }
            }
          ]
        },
        "device_manager": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":                   { "type": "string" },
                "total":                 { "type": "integer" },
                "flagged_count":         { "type": "integer" },
                "missing_drivers":       { "type": ["integer", "null"] },
                "disabled_devices":      { "type": ["integer", "null"] },
                "problem_code_devices":  { "type": ["integer", "null"] },
                "missing_driver_files":  { "type": ["integer", "null"] },
                "old_drivers":           { "type": ["integer", "null"] },
                "unsigned_drivers":      { "type": ["integer", "null"] },
                "driver_events":         { "type": "integer", "description": "Count of System.evtx driver/device events correlated" }
              }
            }
          ]
        },
        "cmos_health": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":    { "type": "string" },
                "verdict":{ "type": "string" },
                "warnings":{ "type": "array", "items": { "type": "string" } }
              }
            }
          ]
        },
        "storage_usage": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":           { "type": "string" },
                "total_gb":      { "type": ["number", "null"] },
                "used_gb":       { "type": ["number", "null"] },
                "free_gb":       { "type": ["number", "null"] },
                "percent_used":  { "type": ["number", "null"] },
                "verdict":       { "type": ["string", "null"] }
              }
            }
          ]
        },
        "disk_integrity": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":              { "type": "string" },
                "verdict":          { "type": "string" },
                "dirty_bit":        { "type": ["boolean", "null"] },
                "total_disk_errors":{ "type": "integer" },
                "total_chkdsk_runs":{ "type": "integer" }
              }
            }
          ]
        },
        "bad_sector_scan": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "log":               { "type": "string" },
                "verdict":           { "type": "string" },
                "risk_status":       { "type": ["string", "null"], "description": "Normalised v2 risk status: OK/SLOW_READS/BAD_SECTORS_FOUND/SCAN_INCOMPLETE/UNSAFE_TO_SCAN/UNKNOWN" },
                "sectors_failed":    { "type": "integer" },
                "sectors_slow":      { "type": "integer" },
                "clone_recommended": { "type": "boolean" },
                "confidence":        { "type": ["string", "null"], "enum": ["high", "medium", "low", "none", null] },
                "limitations":       { "type": "array", "items": { "type": "string" } }
              }
            }
          ]
        },
        "thermal_analysis": {
          "description": "Preferred v2 thermal summary from THERMAL_ANALYSIS (m09). Includes active response test: idle snapshot + CPU stress test + recovery measurement. Use this section in preference to 'thermal' when both are present.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": true,
              "description": "Summary from THERMAL_ANALYSIS including active response test results",
              "properties": {
                "log":                     { "type": "string" },
                "verdict":                 { "type": "string" },
                "warnings":                { "type": "array", "items": { "type": "string" } },
                "hottest_c":               { "type": ["number", "null"] },
                "idle_temp_c":             { "type": ["number", "null"] },
                "peak_temp_c":             { "type": ["number", "null"] },
                "temp_rise_c":             { "type": ["number", "null"] },
                "throttling_detected":     { "type": ["boolean", "null"] },
                "emergency_stop":          { "type": ["boolean", "null"] },
                "response_test_performed": { "type": ["boolean", "null"] },
                "confidence":  { "type": ["string", "null"], "enum": ["high", "medium", "low", "none", null] },
                "limitations": { "type": "array", "items": { "type": "string" }, "description": "e.g. ['no_sensors_found', 'stress_test_skipped']" }
              }
            }
          ]
        }
      }
    }
  }
}
