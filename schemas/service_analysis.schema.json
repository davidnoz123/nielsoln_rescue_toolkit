{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "service_analysis.schema.json",
  "title": "m07 service_analysis",
  "description": "Windows services from offline SYSTEM hive written by m07_service_analysis (v2). Log glob: logs/service_analysis_*.json",
  "type": "object",
  "required": ["generated", "target", "hive", "summary", "services"],
  "additionalProperties": true,
  "properties": {
    "generated": { "type": "string", "description": "ISO 8601 UTC" },
    "target":    { "type": "string" },
    "hive":      { "type": "string" },

    "control_set_context": {
      "type": "object",
      "additionalProperties": true,
      "description": "Active and available control sets resolved from SYSTEM\\Select",
      "properties": {
        "active":            { "type": "string", "examples": ["ControlSet001"] },
        "available":         { "type": "array", "items": { "type": "string" } },
        "current_value":     { "type": ["integer", "null"] },
        "last_known_good":   { "type": ["integer", "null"] },
        "failed_boot_count": { "type": ["integer", "null"] },
        "fallback_used":     { "type": "boolean" }
      }
    },

    "svchost_groups": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "type": "string" } },
      "description": "Svchost group → [service names] from SOFTWARE hive"
    },

    "summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "verdict":               { "type": "string", "enum": ["CLEAN", "REVIEW", "SUSPICIOUS"] },
        "total":                 { "type": "integer" },
        "suspicious_count":      { "type": "integer" },
        "third_party_count":     { "type": "integer" },
        "deleted_count":         { "type": "integer" },
        "auto_start_services":   { "type": "integer" },
        "boot_drivers":          { "type": "integer" },
        "system_drivers":        { "type": "integer" },
        "disabled_count":        { "type": "integer" },
        "missing_binaries":      { "type": "integer" },
        "missing_service_dlls":  { "type": "integer" },
        "unquoted_path_risks":   { "type": "integer" },
        "failure_event_count":   { "type": "integer" },
        "svchost_hosted_count":  { "type": "integer" }
      }
    },

    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name":               { "type": "string" },
          "display_name":       { "type": "string" },
          "start":              { "type": "string", "examples": ["AUTO", "DEMAND", "DISABLED", "BOOT", "SYSTEM"] },
          "type":               { "type": "string" },
          "image_path":         { "type": "string" },
          "resolved_path":      { "type": "string" },
          "path_exists":        { "type": ["boolean", "null"] },
          "object_name":        { "type": "string" },
          "flags":              { "type": "array", "items": { "type": "string" } },
          "suspicious_reason":  { "type": ["string", "null"] },
          "unquoted_path_risk": { "type": "boolean" },
          "svchost_group":      { "type": ["string", "null"] },

          "config": {
            "type": "object",
            "additionalProperties": true,
            "description": "Full decoded service registry configuration",
            "properties": {
              "start_raw":             { "type": ["integer", "null"] },
              "start_name":            { "type": ["string",  "null"] },
              "type_raw":              { "type": ["integer", "null"] },
              "type_flags":            { "type": "array", "items": { "type": "string" } },
              "error_control_raw":     { "type": ["integer", "null"] },
              "error_control":         { "type": ["string",  "null"] },
              "group":                 { "type": ["string",  "null"] },
              "tag":                   { "type": ["integer", "null"] },
              "depend_on_service":     { "type": "array", "items": { "type": "string" } },
              "depend_on_group":       { "type": "array", "items": { "type": "string" } },
              "object_name":           { "type": ["string",  "null"] },
              "description":           { "type": ["string",  "null"] },
              "delayed_auto_start":    { "type": "boolean" },
              "failure_actions": {
                "type": ["object", "null"],
                "additionalProperties": true,
                "properties": {
                  "reset_period_sec": { "type": "integer" },
                  "actions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "type":     { "type": "string" },
                        "delay_ms": { "type": "integer" }
                      }
                    }
                  }
                }
              },
              "failure_command":       { "type": ["string",  "null"] },
              "required_privileges":   { "type": "array", "items": { "type": "string" } },
              "service_sid_type_raw":  { "type": ["integer", "null"] },
              "service_sid_type":      { "type": ["string",  "null"] },
              "launch_protected_raw":  { "type": ["integer", "null"] },
              "launch_protected":      { "type": ["string",  "null"] }
            }
          },

          "file_evidence": {
            "type": "object",
            "additionalProperties": true,
            "description": "File-system evidence for the service binary",
            "properties": {
              "win_path":            { "type": "string" },
              "exists":              { "type": ["boolean", "null"] },
              "size_bytes":          { "type": ["integer", "null"] },
              "modified":            { "type": ["string",  "null"] },
              "sha256":              { "type": ["string",  "null"] },
              "location":            { "type": "string" },
              "suspicious_location": { "type": "boolean" },
              "version_info":        { "type": "object", "additionalProperties": { "type": "string" } },
              "error":               { "type": ["string", "null"] }
            }
          },

          "dll_details": {
            "type": ["object", "null"],
            "additionalProperties": true,
            "description": "ServiceDll details from Parameters subkey (null if not a svchost DLL service)",
            "properties": {
              "ServiceDll":               { "type": "string" },
              "ServiceMain":              { "type": ["string", "null"] },
              "ServiceDllUnloadOnStop":   { "type": ["boolean", "null"] },
              "resolved_path":            { "type": "string" },
              "file_evidence":            { "type": "object", "additionalProperties": true }
            }
          },

          "event_history": {
            "type": ["object", "null"],
            "additionalProperties": true,
            "description": "SCM events from System.evtx (null if evtx not available or no events)",
            "properties": {
              "event_counts":  {
                "type": "object",
                "additionalProperties": { "type": "integer" },
                "description": "event_id (string) → count"
              },
              "recent_events": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "event_id":  { "type": "integer" },
                    "timestamp": { "type": "string" },
                    "category":  { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
