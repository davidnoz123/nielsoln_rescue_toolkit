{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "system_integrity.schema.json",
  "title": "System Integrity Audit",
  "description": "Output of m31_system_integrity_audit.py — offline Windows multi-layer integrity check",
  "type": "object",
  "additionalProperties": true,
  "required": ["generated", "target", "scan_status", "verdict", "confidence"],
  "properties": {
    "generated": {
      "type": "string",
      "description": "ISO-8601 timestamp of when this report was generated"
    },
    "target": {
      "type": "string",
      "description": "Path to the mounted offline Windows installation"
    },
    "windows_version_hint": {
      "type": "string",
      "description": "Best-effort OS version string derived from kernel binary"
    },
    "scan_status": {
      "type": "string",
      "enum": ["complete", "partial", "failed"]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "CLEAN",
        "MINOR_ISSUES",
        "CORRUPTION_SUSPECTED",
        "DISK_RELATED_CORRUPTION_SUSPECTED",
        "TAMPERING_SUSPECTED",
        "INCOMPLETE",
        "UNKNOWN"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files_checked": {
      "type": "integer",
      "minimum": 0
    },
    "protected_files_checked": {
      "type": "integer",
      "minimum": 0
    },
    "missing_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path":     { "type": "string" },
          "category": { "type": "string" }
        }
      }
    },
    "anomalous_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path":         { "type": "string" },
          "category":     { "type": "string" },
          "anomalies":    { "type": "array", "items": { "type": "string" } },
          "sha256":       { "type": ["string", "null"] },
          "size_bytes":   { "type": ["integer", "null"] },
          "modified":     { "type": ["string", "null"] },
          "version_info": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "protected_files_scan": {
      "type": "object",
      "additionalProperties": true,
      "description": "Full protected-file scan results",
      "properties": {
        "checked":  { "type": "integer" },
        "clean":    { "type": "integer" },
        "missing":  { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "anomalous":{ "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "flags":    { "type": "array", "items": { "type": "string" } }
      }
    },
    "winsxs_findings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "winsxs_exists":       { "type": "boolean" },
        "component_count":     { "type": "integer" },
        "manifest_count":      { "type": "integer" },
        "files_with_match":    { "type": "integer" },
        "files_without_match": { "type": "integer" },
        "size_mismatches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "file":           { "type": "string" },
              "system32_bytes": { "type": "integer" },
              "winsxs_bytes":   { "type": "integer" },
              "winsxs_path":    { "type": "string" }
            }
          }
        },
        "flags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "manifest_catalog_findings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "manifests_dir_exists":      { "type": "boolean" },
        "manifest_count":            { "type": "integer" },
        "catroot_exists":            { "type": "boolean" },
        "catroot_cat_count":         { "type": "integer" },
        "catroot2_exists":           { "type": "boolean" },
        "servicing_packages_exists": { "type": "boolean" },
        "servicing_package_count":   { "type": "integer" },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "servicing_findings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cbs_log_found":         { "type": "boolean" },
        "cbs_log_path":          { "type": ["string", "null"] },
        "cbs_log_scanned_bytes": { "type": "integer" },
        "corruption_indicators": { "type": "array", "items": { "type": "string" } },
        "repair_attempts":       { "type": "integer" },
        "failed_repairs":        { "type": "integer" },
        "error_count":           { "type": "integer" },
        "dism_log_found":        { "type": "boolean" },
        "dism_errors":           { "type": "array", "items": { "type": "string" } },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "pending_repair_findings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pending_xml": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "found":              { "type": "boolean" },
            "path":               { "type": ["string", "null"] },
            "pending_operations": { "type": "integer" },
            "pending_renames":    { "type": "integer" },
            "pending_moves":      { "type": "integer" },
            "parse_error":        { "type": ["string", "null"] }
          }
        },
        "pfro_registry_entries": { "type": ["integer", "null"] },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "boot_findings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "boot_mode":       { "type": "string", "enum": ["bios", "uefi", "bios_legacy", "unknown"] },
        "efi_found":       { "type": "boolean" },
        "boot_dir_exists": { "type": "boolean" },
        "bootmgr": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "exists":     { "type": "boolean" },
            "size_bytes": { "type": "integer" },
            "modified":   { "type": "string" }
          }
        },
        "ntldr": {
          "type": "object",
          "additionalProperties": true,
          "properties": { "exists": { "type": "boolean" } }
        },
        "winload_exe": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "exists":     { "type": "boolean" },
            "size_bytes": { "type": "integer" }
          }
        },
        "bcd_store": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "exists":     { "type": "boolean" },
            "path":       { "type": "string" },
            "size_bytes": { "type": "integer" }
          }
        },
        "unusual_boot_files": { "type": "array", "items": { "type": "string" } },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "driver_integrity_findings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hive_available":       { "type": "boolean" },
        "total_drivers":        { "type": "integer" },
        "checked_drivers":      { "type": "integer" },
        "missing_driver_files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name":        { "type": "string" },
              "image_path":  { "type": "string" },
              "start":       { "type": "string" },
              "type":        { "type": "string" }
            }
          }
        },
        "suspicious_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name":       { "type": "string" },
              "image_path": { "type": "string" },
              "start":      { "type": ["integer", "string"] }
            }
          }
        },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "event_log_correlations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "evtx_available":    { "type": "boolean" },
        "disk_io_errors":    { "type": "integer" },
        "controller_resets": { "type": "integer" },
        "driver_failures":   { "type": "integer" },
        "chkdsk_events":     { "type": "integer" },
        "sfc_repair_events": { "type": "integer" },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "cross_module_correlation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disk_health_log":         { "type": ["string", "null"] },
        "disk_health_verdict":     { "type": ["string", "null"] },
        "disk_integrity_log":      { "type": ["string", "null"] },
        "disk_errors_found":       { "type": "boolean" },
        "service_analysis_log":    { "type": ["string", "null"] },
        "service_suspicious":      { "type": "integer" },
        "persistence_log":         { "type": ["string", "null"] },
        "persistence_suspicious":  { "type": "integer" },
        "device_manager_log":      { "type": ["string", "null"] },
        "device_problem_count":    { "type": "integer" },
        "combined_signals":        { "type": "array", "items": { "type": "string" } },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
